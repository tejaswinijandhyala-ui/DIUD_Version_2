# Copy this file to .env and fill in real values.
# Every variable here is read somewhere specific in the codebase --
# see the comment on each line for exactly where.

# --- ClickHouse ------------------------------------------------------
# Read by: tools/clickhouse.py ONLY -- this is exclusively your real
# business analytics database (hs_analytics.*, kore_ai_hubspot.*).
# Conversation memory, feedback, and observability no longer use
# ClickHouse at all -- see memory/session_store.py, governance/
# feedback_store.py, and observability/logger.py for why.
CLICKHOUSE_URL=https://your-clickhouse-host/query
CLICKHOUSE_TOKEN=

# --- Anthropic ---------------------------------------------------------
# Read implicitly by the anthropic SDK (anthropic.Anthropic()) in every
# agent file (agents/intent_agent.py, agents/sql_agent.py,
# agents/insight_agent.py, agents/governance_agent.py) and in
# tools/export_builders.py, governance/audit_log.py
ANTHROPIC_API_KEY=

# --- Admin surface -----------------------------------------------------
# Read by: api/admin_routes.py
# If this is unset, every /debug/* endpoint returns 503 rather than
# silently being left open -- see admin_routes.py's _require_admin().
DEV_ADMIN_TOKEN=
